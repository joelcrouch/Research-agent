# Academic Research Intelligence Agent - Environment Variables

# --- Required API Keys (Cloud LLM Mode) ---
# Set USE_LOCAL_LLM=true if you want to use Ollama instead of Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LANGSMITH_API_KEY=your_langsmith_api_key_here

# --- Optional Project Config ---
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LANGSMITH_PROJECT=research-agent
DEFAULT_TOP_K=10
DEFAULT_DATE_RANGE_YEARS=5

# --- Local LLM Config (Ollama) ---
USE_LOCAL_LLM=false
LOCAL_LLM_MODEL=llama3:latest
LOCAL_LLM_BASE_URL=http://localhost:11434
